<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/header_dark"
        android:elevation="0dp"
        app:title="Borrow Item"
        app:titleTextColor="@color/white"
        app:navigationIconTint="@color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Item info card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/primary"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BORROWING"
                        android:textColor="@color/white"
                        android:alpha="0.6"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold"
                        android:letterSpacing="0.10"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/tvItemName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:text="Item Name"
                        android:textColor="@color/white"
                        android:textSize="22sp"/>
                    <TextView
                        android:id="@+id/tvMaxQty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Max available: 0"
                        android:textColor="@color/white"
                        android:alpha="0.75"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Form card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Quantity"
                        android:textColor="@color/gray_700"
                        android:textSize="12sp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.TechLoan.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etQuantity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="1"
                            android:inputType="number"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Purpose"
                        android:textColor="@color/gray_700"
                        android:textSize="12sp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.TechLoan.TextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPurpose"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Describe your purpose..."
                            android:inputType="textMultiLine"
                            android:lines="3"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Return Date"
                        android:textColor="@color/gray_700"
                        android:textSize="12sp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPickDate"
                        style="@style/Widget.TechLoan.OutlineButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginBottom="6dp"
                        android:text="Pick a Date"/>

                    <TextView
                        android:id="@+id/tvSelectedDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:fontFamily="sans-serif-medium"
                        android:text=""
                        android:textColor="@color/primary"
                        android:textSize="13sp"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="8dp"
                        android:indeterminateTint="@color/primary"
                        android:visibility="gone"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubmit"
                        style="@style/Widget.TechLoan.Button"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Submit Request"
                        android:textSize="15sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
